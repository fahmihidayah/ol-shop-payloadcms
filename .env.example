DATABASE_URL=postgresql://postgres:[your-password]@localhost:3000/railway
PAYLOAD_SECRET=secreet
DATABASE_AUTH_TOKEN=database-auth-token
DUITKU_MERCHANT_CODE=merchant-code

# API Key (Authentication Code)
DUITKU_API_KEY=191c67ee614094f32f1c776306b284cc

# Environment: 'sandbox' or 'production'
DUITKU_ENVIRONMENT=sandbox

# Callback URL - Duitku will send payment notifications here
DUITKU_CALLBACK_URL=http://localhost:3000/api/payment/callback

# Return URL - User will be redirected here after payment
DUITKU_RETURN_URL=http://localhost:3000/order/confirmation

# Expiry period in minutes (default: 1440 = 24 hours)
DUITKU_EXPIRY_PERIOD=1440

# Next.js Base URL
NEXT_PUBLIC_BASE_URL=http://localhost:3000

CLOUD_STORAGE_BUCKET=ol-shop
CLOUD_STORAGE_ENDPOINT=your-endpoint-s3-bucket
CLOUD_STORAGE_ACCESS_KEY=your-accesskey
CLOUD_STORAGE_SECRET=your-secretkey

# Email Configuration
# Provider: 'resend' | 'nodemailer' | 'console'
EMAIL_PROVIDER=console

# From address configuration
EMAIL_FROM_NAME=Online Store
EMAIL_FROM_ADDRESS=noreply@example.com

# Company Information (for email templates)
COMPANY_ADDRESS=123 Main Street, Jakarta, Indonesia
COMPANY_CONTACT=support@example.com | +62 21 1234 5678

# Social Media Links (optional - for email footer)
SOCIAL_FACEBOOK=https://facebook.com/yourpage
SOCIAL_INSTAGRAM=https://instagram.com/yourpage
SOCIAL_TWITTER=https://twitter.com/yourpage

# Resend Configuration (if EMAIL_PROVIDER=resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# NodeMailer/SMTP Configuration (if EMAIL_PROVIDER=nodemailer)
# For MailHog (local development):
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_SECURE=false
# Leave SMTP_USER and SMTP_PASS empty for MailHog

# For Gmail or other SMTP providers:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password